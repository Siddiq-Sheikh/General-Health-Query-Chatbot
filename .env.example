# .env — Add your secrets here. Never commit this file to Git.

# Get your free API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Model to use (free options available on OpenRouter)
MODEL=mistralai/mistral-7b-instruct:free

# Optional tuning
MAX_TOKENS=512
TEMPERATURE=0.7
